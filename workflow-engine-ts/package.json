{
  "name": "workflow-engine",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc --build",
    "start": "ts-node src/run/worker.ts",
    "start.watch": "nodemon src/run/worker.ts",
    "workflow": "ts-node src/run/client.ts",
    "hello": "ts-node src/run/client.ts --hello",
    "test": "jest --config jest.config.js",
    "test.watch": "jest --config jest.config.js --watch"
  },
  "nodemonConfig": {
    "execMap": { "ts": "ts-node" },
    "ext": "ts",
    "watch": ["src"]
  },
  "dependencies": {
    "@temporalio/activity": "^1.9.0",
    "@temporalio/client": "^1.9.0",
    "@temporalio/worker": "^1.9.0",
    "@temporalio/workflow": "^1.9.0",
    "jsdom": "^24.0.0"
  },
  "devDependencies": {
    "@temporalio/testing": "^1.9.0",
    "@types/jest": "^29.5.0",
    "@types/jsdom": "^21.1.0",
    "@types/node": "^20.11.0",
    "jest": "^30.0.0",
    "nodemon": "^3.1.14",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}
